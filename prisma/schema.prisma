generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  width     Int?
  height    Int?
  caption   String?
  category  String   @default("wedding")
  createdAt DateTime @default(now())
}

model RSVP {
  id        String   @id @default(cuid())
  name      String
  attending Boolean
  guests    Int      @default(1)
  message   String?
  createdAt DateTime @default(now())
}
